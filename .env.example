# GitHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── LLM 프로바이더 설정 ──────────────────────────────────────
# 선택: anthropic | ollama | openai | openai_compatible
LLM_PROVIDER=anthropic

# Anthropic (LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-
CLAUDE_MODEL=claude-sonnet-4-6

# Ollama — 로컬 LLM (LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# OpenAI / OpenAI-compatible (LLM_PROVIDER=openai 또는 openai_compatible)
# LM Studio, vLLM, LocalAI 등 OpenAI 호환 서버도 사용 가능
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=http://localhost:1234/v1   # 로컬 서버일 때만 설정
# ──────────────────────────────────────────────────────────────

# 범용 CI webhook 토큰 (git runner → /webhook/ci 호출 시 인증)
CI_WEBHOOK_TOKEN=

# Slack
SLACK_BOT_TOKEN=xoxb-
SLACK_ALERT_CHANNEL=#ci-alerts
APPROVAL_TIMEOUT_SECONDS=300

# Storage
DB_PATH=data/healing.db
